<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Qualcomm (EDL) Service"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnQcDetect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Detect EDL Device"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnQcReadPartitions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Read Partitions"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Service Operations:"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnQcRemoveFrp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Remove FRP"
        android:textColor="#FF5722"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btnQcFactoryReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Factory Reset"
        android:textColor="#F44336"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btnQcRemoveLock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Remove Screen Lock"
        android:textColor="#FF9800"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btnQcWipeModem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wipe Modem Data"
        android:textColor="#9C27B0"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Flash Operations:"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnQcProgram"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Program Partition"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btnQcErase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Erase Partition"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btnQcRead"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Read Partition"
        android:layout_marginBottom="4dp" />

    <ProgressBar
        android:id="@+id/progressQc"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:visibility="gone"
        android:layout_marginTop="8dp" />

</LinearLayout>